# Server Configuration
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartheal_db
DB_USER=postgres
DB_PASSWORD=postgres123

# Firebase Configuration
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email@firebase.gserviceaccount.com

# API Configuration
API_VERSION=v1
CORS_ORIGIN=http://localhost:3000,http://localhost:19000,http://localhost:8081

# JWT Configuration (Optional, if issuing custom JWTs)
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRY=24h
